-- One-Shot Aimbot for Duels: Murderers vs Sheriffs (Mobile Optimized)
-- Fixed dragging on mobile, ultra-compact, persistent

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer

-- Settings
local cooldownTime = 2.5
local lastShotTime = 0
local canShoot = true

-- GUI references
local ScreenGui = nil
local Frame = nil
local ShootButton = nil

-- Function to create the GUI
local function createGUI()
    if ScreenGui then
        ScreenGui:Destroy()
    end
    
    local playerGui = player:WaitForChild("PlayerGui")
    
    ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "OneShotAimbotGUI"
    ScreenGui.Parent = playerGui
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.ResetOnSpawn = false  -- Keep GUI across respawns
    
    -- Small square frame (45x45)
    Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0, 45, 0, 45)
    Frame.Position = UDim2.new(0.5, -22, 0, 10)
    Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Frame.BackgroundTransparency = 0.3
    Frame.BorderSizePixel = 0
    Frame.Parent = ScreenGui
    Frame.Active = true
    Frame.ZIndex = 10  -- High ZIndex to capture touches
    
    -- Shoot Button
    ShootButton = Instance.new("TextButton")
    ShootButton.Size = UDim2.new(1, 0, 1, 0)
    ShootButton.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
    ShootButton.Text = "🔫"
    ShootButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    ShootButton.Font = Enum.Font.GothamBold
    ShootButton.TextSize = 24
    ShootButton.Parent = Frame
    ShootButton.ZIndex = 10
    
    -- UI Styling
    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(0, 8)
    UICorner.Parent = Frame
    
    local UIStroke = Instance.new("UIStroke")
    UIStroke.Color = Color3.fromRGB(255, 255, 255)
    UIStroke.Thickness = 1.5
    UIStroke.Parent = Frame
    
    local ButtonCorner = Instance.new("UICorner")
    ButtonCorner.CornerRadius = UDim.new(0, 8)
    ButtonCorner.Parent = ShootButton
    
    -- =====================
    -- IMPROVED DRAGGING FOR MOBILE
    -- =====================
    local dragConnection = nil
    local isDragging = false
    local dragStartPos = nil
    local frameStartPos = nil
    local DRAG_THRESHOLD = 10  -- pixels, prevents accidental drag when tapping to shoot
    
    local function startDrag(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            dragStartPos = input.Position
            frameStartPos = Frame.Position
            
            -- Connect to TouchMoved
            if dragConnection then dragConnection:Disconnect() end
            dragConnection = UserInputService.TouchMoved:Connect(function(touchInput)
                if isDragging and touchInput == input then
                    local delta = touchInput.Position - dragStartPos
                    if delta.Magnitude > DRAG_THRESHOLD then
                        Frame.Position = UDim2.new(
                            frameStartPos.X.Scale,
                            frameStartPos.X.Offset + delta.X,
                            frameStartPos.Y.Scale,
                            frameStartPos.Y.Offset + delta.Y
                        )
                    end
                end
            end)
        end
    end
    
    local function stopDrag(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
            if dragConnection then
                dragConnection:Disconnect()
                dragConnection = nil
            end
        end
    end
    
    -- Use InputBegan/Ended on the Frame for touch
    Frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            startDrag(input)
        end
    end)
    
    Frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            stopDrag(input)
        end
    end)
    
    -- Also handle mouse dragging for PC
    Frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            startDrag(input)
        end
    end)
    
    Frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            stopDrag(input)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStartPos
            if delta.Magnitude > DRAG_THRESHOLD then
                Frame.Position = UDim2.new(
                    frameStartPos.X.Scale,
                    frameStartPos.X.Offset + delta.X,
                    frameStartPos.Y.Scale,
                    frameStartPos.Y.Offset + delta.Y
                )
            end
        end
    end)
    
    -- =====================
    -- SHOOTING FUNCTIONALITY
    -- =====================
    ShootButton.MouseButton1Click:Connect(function()
        if not isDragging then  -- Only shoot if we didn't just drag
            attemptShot()
        end
    end)
    
    ShootButton.TouchTap:Connect(function()
        if not isDragging then
            attemptShot()
        end
    end)
    
    -- Reset state
    canShoot = true
    lastShotTime = 0
    ShootButton.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
    ShootButton.Text = "🔫"
end

-- Helper Functions (unchanged, condensed for brevity)
local function getWeapon()
    local char = player.Character
    if not char then return nil end
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") and tool:FindFirstChild("fire") then return tool end
    end
    local bp = player:FindFirstChild("Backpack")
    if bp then
        for _, tool in pairs(bp:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("fire") then
                tool.Parent = char
                return tool
            end
        end
    end
    return nil
end

local function hasClearLineOfSight(targetPlayer)
    local char = player.Character
    local tChar = targetPlayer.Character
    if not char or not tChar then return false end
    local myRoot = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    local tRoot = tChar:FindFirstChild("HumanoidRootPart") or tChar:FindFirstChild("Torso")
    if not myRoot or not tRoot then return false end
    local startPos = myRoot.Position
    local endPos = tRoot.Position
    local dir = (endPos - startPos).Unit
    local dist = (endPos - startPos).Magnitude
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {char, tChar}
    params.IgnoreWater = true
    local result = Workspace:Raycast(startPos, dir * dist, params)
    return result == nil
end

local function getNearestVisibleEnemy()
    local char = player.Character
    if not char then return nil end
    local myRoot = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if not myRoot then return nil end
    local nearest = nil
    local minDist = math.huge
    for _, other in pairs(Players:GetPlayers()) do
        if other ~= player and other.Character then
            local oChar = other.Character
            local hum = oChar:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local oRoot = oChar:FindFirstChild("HumanoidRootPart") or oChar:FindFirstChild("Torso")
                if oRoot then
                    local dist = (myRoot.Position - oRoot.Position).Magnitude
                    if dist < minDist and hasClearLineOfSight(other) then
                        minDist = dist
                        nearest = other
                    end
                end
            end
        end
    end
    return nearest
end

local function shootEnemy(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return false end
    local char = player.Character
    if not char then return false end
    local weapon = getWeapon()
    if not weapon then return false end
    local handle = weapon:FindFirstChild("Handle")
    if not handle then return false end
    local tRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart") or targetPlayer.Character:FindFirstChild("Torso")
    if not tRoot then return false end
    
    local startPos = handle.Position
    local hitPos = tRoot.Position
    
    -- Client beam
    local localBeam = ReplicatedStorage:FindFirstChild("BindableEvents"):FindFirstChild("LocalBeam")
    if localBeam then pcall(function() localBeam:Fire(handle, hitPos) end) end
    
    -- Fire remote
    local fireRemote = weapon:FindFirstChild("fire")
    if fireRemote then pcall(function() fireRemote:FireServer() end) end
    
    -- showBeam (hit, start, handle)
    local beamRemote = weapon:FindFirstChild("showBeam")
    if beamRemote then pcall(function() beamRemote:FireServer(hitPos, startPos, handle) end) end
    
    -- Kill remote
    local killRemote = weapon:FindFirstChild("kill")
    if killRemote then
        local dir = (hitPos - startPos).Unit
        pcall(function() killRemote:FireServer(targetPlayer, dir) end)
    end
    
    -- Optional Killed
    pcall(function()
        local killed = ReplicatedStorage:FindFirstChild("Remotes"):FindFirstChild("Killed")
        if killed then killed:FireServer(targetPlayer) end
    end)
    return true
end

local function startCooldown()
    canShoot = false
    lastShotTime = tick()
    ShootButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    ShootButton.Text = "⏳"
    task.spawn(function()
        while tick() - lastShotTime < cooldownTime do task.wait(0.1) end
        canShoot = true
        ShootButton.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
        ShootButton.Text = "🔫"
    end)
end

function attemptShot()
    if not canShoot then return end
    if not getWeapon() then return end
    local target = getNearestVisibleEnemy()
    if target and shootEnemy(target) then
        startCooldown()
    end
end

-- Respawn handling
player.CharacterAdded:Connect(function(char)
    task.wait(0.1)
    createGUI()
end)

if player.Character then
    createGUI()
else
    player.CharacterAdded:Wait()
    createGUI()
end

print("One-Shot Aimbot Loaded - Mobile Dragging Fixed!")
