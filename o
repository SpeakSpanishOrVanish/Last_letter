-- One-Shot Aimbot for Duels: Murderers vs Sheriffs (Mobile Friendly)
-- Ultra-compact square button, no text label, persistent through respawns

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

-- Settings
local cooldownTime = 2.5
local lastShotTime = 0
local canShoot = true

-- GUI references
local ScreenGui = nil
local Frame = nil
local ShootButton = nil

-- Function to create the GUI
local function createGUI()
    if ScreenGui then
        ScreenGui:Destroy()
    end
    
    local playerGui = player:WaitForChild("PlayerGui")
    
    ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "OneShotAimbotGUI"
    ScreenGui.Parent = playerGui
    
    -- Small square frame (45x45)
    Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0, 45, 0, 45)
    Frame.Position = UDim2.new(0.5, -22, 0, 10)
    Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Frame.BackgroundTransparency = 0.3
    Frame.BorderSizePixel = 0
    Frame.Parent = ScreenGui
    Frame.Active = true  -- Allow input on frame
    
    -- Dragging functionality
    local dragging = false
    local dragStartPos = nil
    local frameStartPos = nil
    
    Frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStartPos = input.Position
            frameStartPos = Frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStartPos
            Frame.Position = UDim2.new(
                frameStartPos.X.Scale,
                frameStartPos.X.Offset + delta.X,
                frameStartPos.Y.Scale,
                frameStartPos.Y.Offset + delta.Y
            )
        end
    end)
    
    -- Shoot Button (fills frame, shows status via emoji/color)
    ShootButton = Instance.new("TextButton")
    ShootButton.Size = UDim2.new(1, 0, 1, 0)
    ShootButton.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
    ShootButton.Text = "🔫"
    ShootButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    ShootButton.Font = Enum.Font.GothamBold
    ShootButton.TextSize = 24
    ShootButton.Parent = Frame
    ShootButton.ZIndex = 2
    
    -- UI Styling
    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(0, 8)
    UICorner.Parent = Frame
    
    local UIStroke = Instance.new("UIStroke")
    UIStroke.Color = Color3.fromRGB(255, 255, 255)
    UIStroke.Thickness = 1.5
    UIStroke.Parent = Frame
    
    local ButtonCorner = Instance.new("UICorner")
    ButtonCorner.CornerRadius = UDim.new(0, 8)
    ButtonCorner.Parent = ShootButton
    
    -- Connect button
    ShootButton.MouseButton1Click:Connect(attemptShot)
    ShootButton.TouchTap:Connect(attemptShot)
    
    -- Reset state
    canShoot = true
    lastShotTime = 0
    ShootButton.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
    ShootButton.Text = "🔫"
end

-- Helper Functions
local function getWeapon()
    local character = player.Character
    if not character then return nil end
    
    for _, tool in pairs(character:GetChildren()) do
        if tool:IsA("Tool") and tool:FindFirstChild("fire") then
            return tool
        end
    end
    
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, tool in pairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("fire") then
                tool.Parent = character
                return tool
            end
        end
    end
    
    return nil
end

local function hasClearLineOfSight(targetPlayer)
    local character = player.Character
    local targetChar = targetPlayer.Character
    if not character or not targetChar then return false end
    
    local myRoot = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart") or targetChar:FindFirstChild("Torso")
    if not myRoot or not targetRoot then return false end
    
    local startPos = myRoot.Position
    local endPos = targetRoot.Position
    local direction = (endPos - startPos).Unit
    local distance = (endPos - startPos).Magnitude
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {character, targetChar}
    raycastParams.IgnoreWater = true
    
    local raycastResult = Workspace:Raycast(startPos, direction * distance, raycastParams)
    return raycastResult == nil
end

local function getNearestVisibleEnemy()
    local character = player.Character
    if not character then return nil end
    
    local myRoot = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
    if not myRoot then return nil end
    
    local nearest = nil
    local minDist = math.huge
    
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character then
            local otherChar = otherPlayer.Character
            local humanoid = otherChar:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local otherRoot = otherChar:FindFirstChild("HumanoidRootPart") or otherChar:FindFirstChild("Torso")
                if otherRoot then
                    local dist = (myRoot.Position - otherRoot.Position).Magnitude
                    if dist < minDist and hasClearLineOfSight(otherPlayer) then
                        minDist = dist
                        nearest = otherPlayer
                    end
                end
            end
        end
    end
    
    return nearest
end

local function shootEnemy(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return false end
    
    local character = player.Character
    if not character then return false end
    
    local weapon = getWeapon()
    if not weapon then return false end
    
    local handle = weapon:FindFirstChild("Handle")
    if not handle then return false end
    
    local targetChar = targetPlayer.Character
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart") or targetChar:FindFirstChild("Torso")
    if not targetRoot then return false end
    
    local startPos = handle.Position
    local hitPos = targetRoot.Position
    
    -- Client-side beam
    local localBeam = ReplicatedStorage:FindFirstChild("BindableEvents"):FindFirstChild("LocalBeam")
    if localBeam then
        pcall(function() localBeam:Fire(handle, hitPos) end)
    end
    
    -- Fire remote
    local fireRemote = weapon:FindFirstChild("fire")
    if fireRemote then
        pcall(function() fireRemote:FireServer() end)
    end
    
    -- ShowBeam remote (hitPos, startPos, handle)
    local beamRemote = weapon:FindFirstChild("showBeam")
    if beamRemote then
        pcall(function() beamRemote:FireServer(hitPos, startPos, handle) end)
    end
    
    -- Kill remote
    local killRemote = weapon:FindFirstChild("kill")
    if killRemote then
        local direction = (hitPos - startPos).Unit
        pcall(function() killRemote:FireServer(targetPlayer, direction) end)
    end
    
    -- Optional Killed remote
    pcall(function()
        local killedRemote = ReplicatedStorage:FindFirstChild("Remotes"):FindFirstChild("Killed")
        if killedRemote then
            killedRemote:FireServer(targetPlayer)
        end
    end)
    
    return true
end

local function startCooldown()
    canShoot = false
    lastShotTime = tick()
    ShootButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    ShootButton.Text = "⏳"
    
    task.spawn(function()
        while tick() - lastShotTime < cooldownTime do
            task.wait(0.1)
        end
        canShoot = true
        ShootButton.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
        ShootButton.Text = "🔫"
    end)
end

function attemptShot()
    if not canShoot then return end
    
    local weapon = getWeapon()
    if not weapon then return end
    
    local target = getNearestVisibleEnemy()
    if target then
        local success = shootEnemy(target)
        if success then
            startCooldown()
        end
    end
end

-- Respawn handling
player.CharacterAdded:Connect(function(character)
    task.wait(0.1)
    createGUI()
end)

if player.Character then
    createGUI()
else
    player.CharacterAdded:Wait()
    createGUI()
end

print("==========================================")
print("ONE-SHOT AIMBOT LOADED (TINY SQUARE BUTTON)")
print("GUI persists through respawns")
print("==========================================")
