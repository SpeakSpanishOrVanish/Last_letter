-- One-Shot Aimbot for Duels: Murderers vs Sheriffs
-- Hollow circle button, robust two-finger drag, position memory

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

-- Settings
local cooldownTime = 2.5
local lastShotTime = 0
local canShoot = true

-- GUI
local ScreenGui = nil
local Button = nil

-- Position memory
local savedPosition = UDim2.new(0.5, -30, 0, 10)  -- 60px button

-- Drag state
local activeTouch = nil  -- The touch currently dragging the button
local dragOffset = Vector2.zero
local dragThreshold = 10

-- Cache
local camera = Workspace.CurrentCamera
local localBeam = ReplicatedStorage:FindFirstChild("BindableEvents"):FindFirstChild("LocalBeam")
local killedRemote = ReplicatedStorage:FindFirstChild("Remotes"):FindFirstChild("Killed")

-- Clamp to screen
local function clampToScreen(position)
    local screenSize = camera.ViewportSize
    local buttonSize = Button.AbsoluteSize
    return UDim2.new(0, math.clamp(position.X.Offset, 0, screenSize.X - buttonSize.X), 0, math.clamp(position.Y.Offset, 0, screenSize.Y - buttonSize.Y))
end

-- Check if a position is inside the button
local function isTouchOnButton(touchPos)
    local btnPos = Button.AbsolutePosition
    local btnSize = Button.AbsoluteSize
    return touchPos.X >= btnPos.X and touchPos.X <= btnPos.X + btnSize.X and touchPos.Y >= btnPos.Y and touchPos.Y <= btnPos.Y + btnSize.Y
end

-- Create GUI
local function createGUI()
    if ScreenGui then ScreenGui:Destroy() end
    
    local playerGui = player:WaitForChild("PlayerGui")
    
    ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "OneShotAimbotGUI"
    ScreenGui.Parent = playerGui
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.IgnoreGuiInset = true
    ScreenGui.ResetOnSpawn = false
    
    -- Hollow circle button (60x60)
    Button = Instance.new("TextButton")
    Button.Size = UDim2.new(0, 60, 0, 60)
    Button.Position = savedPosition
    Button.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Button.BackgroundTransparency = 0.9  -- Almost fully transparent
    Button.Text = ""  -- No icon
    Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    Button.Font = Enum.Font.GothamBold
    Button.TextSize = 0
    Button.Parent = ScreenGui
    Button.ZIndex = 10
    Button.Active = true
    Button.AutoButtonColor = false
    Button.BorderSizePixel = 0
    
    -- Circular outline
    local corner = Instance.new("UICorner", Button)
    corner.CornerRadius = UDim.new(1, 0)  -- Fully round
    
    local stroke = Instance.new("UIStroke", Button)
    stroke.Thickness = 2.5
    stroke.Color = Color3.fromRGB(255, 255, 255)
    stroke.Transparency = 0.2
    stroke.LineJoinMode = Enum.LineJoinMode.Round
    
    -- === ROBUST DRAGGING (Touch/Mouse) ===
    local dragConnection = nil
    
    local function startDrag(input)
        if activeTouch then return end  -- Already dragging
        local pos = input.Position
        if isTouchOnButton(pos) then
            activeTouch = input
            dragOffset = pos - Button.AbsolutePosition
            
            -- Start render loop
            if dragConnection then dragConnection:Disconnect() end
            dragConnection = RunService.RenderStepped:Connect(function()
                if activeTouch then
                    local currentPos = activeTouch.Position
                    local newPos = UDim2.new(0, currentPos.X - dragOffset.X, 0, currentPos.Y - dragOffset.Y)
                    local clamped = clampToScreen(newPos)
                    Button.Position = clamped
                    savedPosition = clamped
                else
                    dragConnection:Disconnect()
                    dragConnection = nil
                end
            end)
        end
    end
    
    local function stopDrag(input)
        if activeTouch == input then
            activeTouch = nil
        end
    end
    
    -- Listen for all touches
    UserInputService.TouchStarted:Connect(function(touch, gameProcessed)
        -- Only handle if not already dragging and touch is on button
        if not activeTouch and isTouchOnButton(touch.Position) then
            startDrag(touch)
        end
    end)
    
    UserInputService.TouchMoved:Connect(function(touch)
        -- If this touch is our active drag touch, movement is handled in RenderStepped
    end)
    
    UserInputService.TouchEnded:Connect(function(touch)
        stopDrag(touch)
    end)
    
    -- Mouse support (PC)
    Button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            startDrag(input)
        end
    end)
    
    Button.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            stopDrag(input)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and activeTouch == input then
            -- Handled in RenderStepped
        end
    end)
    
    -- === SHOOTING (only on tap, not drag) ===
    local tapStartPos = nil
    local tapTouch = nil
    
    UserInputService.TouchStarted:Connect(function(touch, gameProcessed)
        if isTouchOnButton(touch.Position) then
            tapStartPos = touch.Position
            tapTouch = touch
        end
    end)
    
    UserInputService.TouchEnded:Connect(function(touch)
        if tapTouch == touch and tapStartPos then
            local endPos = touch.Position
            if (endPos - tapStartPos).Magnitude <= dragThreshold then
                task.spawn(attemptShot)
            end
            tapStartPos = nil
            tapTouch = nil
        end
    end)
    
    -- Mouse click
    Button.MouseButton1Click:Connect(function()
        task.spawn(attemptShot)
    end)
    
    -- Reset visual state
    canShoot = true
    lastShotTime = 0
    stroke.Color = Color3.fromRGB(255, 255, 255)
end

-- === Weapon & Combat (unchanged) ===
local function getWeapon()
    local char = player.Character
    if not char then return nil end
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") and tool:FindFirstChild("fire") then return tool end
    end
    local bp = player:FindFirstChild("Backpack")
    if bp then
        for _, tool in pairs(bp:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("fire") then
                tool.Parent = char
                return tool
            end
        end
    end
    return nil
end

local function hasClearLineOfSight(targetPlayer)
    local char = player.Character
    local tChar = targetPlayer.Character
    if not char or not tChar then return false end
    local myRoot = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    local tRoot = tChar:FindFirstChild("HumanoidRootPart") or tChar:FindFirstChild("Torso")
    if not myRoot or not tRoot then return false end
    local dir = (tRoot.Position - myRoot.Position).Unit
    local dist = (tRoot.Position - myRoot.Position).Magnitude
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {char, tChar}
    params.IgnoreWater = true
    return workspace:Raycast(myRoot.Position, dir * dist, params) == nil
end

local function getNearestVisibleEnemy()
    local char = player.Character
    if not char then return nil end
    local myRoot = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if not myRoot then return nil end
    local nearest, minDist = nil, math.huge
    for _, other in pairs(Players:GetPlayers()) do
        if other ~= player and other.Character then
            local oChar = other.Character
            local hum = oChar:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local oRoot = oChar:FindFirstChild("HumanoidRootPart") or oChar:FindFirstChild("Torso")
                if oRoot then
                    local dist = (myRoot.Position - oRoot.Position).Magnitude
                    if dist < minDist and hasClearLineOfSight(other) then
                        minDist = dist
                        nearest = other
                    end
                end
            end
        end
    end
    return nearest
end

local function shootEnemy(targetPlayer)
    local char = player.Character
    if not char or not targetPlayer.Character then return false end
    
    local weapon = getWeapon()
    if not weapon then return false end
    
    local handle = weapon:FindFirstChild("Handle")
    if not handle then return false end
    
    local tRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart") or targetPlayer.Character:FindFirstChild("Torso")
    if not tRoot then return false end
    
    local startPos = handle.Position
    local hitPos = tRoot.Position
    
    if localBeam then pcall(function() localBeam:Fire(handle, hitPos) end) end
    
    local fireRemote = weapon:FindFirstChild("fire")
    if fireRemote then pcall(function() fireRemote:FireServer() end) end
    
    local beamRemote = weapon:FindFirstChild("showBeam")
    if beamRemote then pcall(function() beamRemote:FireServer(hitPos, startPos, handle) end) end
    
    local killRemote = weapon:FindFirstChild("kill")
    if killRemote then
        local dir = (hitPos - startPos).Unit
        pcall(function() killRemote:FireServer(targetPlayer, dir) end)
    end
    
    if killedRemote then pcall(function() killedRemote:FireServer(targetPlayer) end) end
    
    return true
end

local function startCooldown()
    canShoot = false
    lastShotTime = tick()
    -- Change stroke color to gray during cooldown
    local stroke = Button:FindFirstChildOfClass("UIStroke")
    if stroke then stroke.Color = Color3.fromRGB(150, 150, 150) end
    
    task.spawn(function()
        while tick() - lastShotTime < cooldownTime do
            task.wait(0.1)
        end
        canShoot = true
        if stroke then stroke.Color = Color3.fromRGB(255, 255, 255) end
    end)
end

function attemptShot()
    if not canShoot then return end
    local target = getNearestVisibleEnemy()
    if target and shootEnemy(target) then
        startCooldown()
    end
end

-- Respawn handling
player.CharacterAdded:Connect(function()
    task.wait(0.1)
    createGUI()
    camera = Workspace.CurrentCamera
end)

if player.Character then
    createGUI()
else
    player.CharacterAdded:Wait()
    createGUI()
end

print("Aimbot Loaded – Hollow circle, two-finger drag ready!")
