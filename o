-- Make frame draggable
local dragging = false
local dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

Button.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = Frame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

Button.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)

-- Variables
local autoAiming = false
local connection
local lastShot = 0
local shotCooldown = 0.5 -- Cooldown between shots in seconds

-- Function to get nearest enemy with improved targeting
local function getNearestEnemy()
    local nearestPlayer = nil
    local nearestDistance = math.huge
    local character = player.Character
    if not character then return nil end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
    if not rootPart then return nil end
    
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character then
            local otherChar = otherPlayer.Character
            local humanoid = otherChar:FindFirstChild("Humanoid")
            
            -- Check if player is alive
            if humanoid and humanoid.Health > 0 then
                local otherRoot = otherChar:FindFirstChild("HumanoidRootPart") or otherChar:FindFirstChild("Torso")
                if otherRoot then
                    local distance = (rootPart.Position - otherRoot.Position).Magnitude
                    
                    -- Check line of sight (optional, can be removed if causing issues)
                    local raycastParams = RaycastParams.new()
                    raycastParams.FilterDescendantsInstances = {character, otherChar}
                    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
                    raycastParams.IgnoreWater = true
                    
                    local raycastResult = Workspace:Raycast(rootPart.Position, (otherRoot.Position - rootPart.Position).Unit * distance, raycastParams)
                    
                    if not raycastResult or raycastResult.Instance:IsDescendantOf(otherChar) then
                        if distance < nearestDistance then
                            nearestDistance = distance
                            nearestPlayer = otherPlayer
                        end
                    end
                end
            end
        end
    end
    
    return nearestPlayer, nearestDistance
end

-- Function to get KatanaPistol tool
local function getKatanaPistol()
    local character = player.Character
    if not character then return nil end
    
    -- Check character first
    local katanaPistol = character:FindFirstChild("KatanaPistol")
    if katanaPistol then
        return katanaPistol
    end
    
    -- Check backpack
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        katanaPistol = backpack:FindFirstChild("KatanaPistol")
        if katanaPistol then
            -- Equip it
            katanaPistol.Parent = character
            return katanaPistol
        end
    end
    
    -- Check workspace (might be on ground)
    katanaPistol = Workspace:FindFirstChild("KatanaPistol")
    if katanaPistol and katanaPistol:IsA("Tool") then
        katanaPistol.Parent = character
        return katanaPistol
    end
    
    return nil
end

-- Function to equip second weapon if KatanaPistol not found
local function equipSecondWeapon()
    local character = player.Character
    if not character then return nil end
    
    -- Try backpack
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        local tools = {}
        for _, item in pairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                table.insert(tools, item)
            end
        end
        
        if #tools >= 2 then
            -- Unequip current tools
            for _, tool in pairs(character:GetChildren()) do
                if tool:IsA("Tool") then
                    tool.Parent = backpack
                end
            end
            
            -- Equip second tool
            tools[2].Parent = character
            return tools[2]
        elseif #tools == 1 then
            -- Equip only tool
            for _, tool in pairs(character:GetChildren()) do
                if tool:IsA("Tool") then
                    tool.Parent = backpack
                end
            end
            tools[1].Parent = character
            return tools[1]
        end
    end
    
    -- Check if already have weapon
    for _, item in pairs(character:GetChildren()) do
        if item:IsA("Tool") then
            return item
        end
    end
    
    return nil
end

-- Function to execute complete shooting sequence
local function shootEnemy(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return false end
    
    local character = player.Character
    if not character then return false end
    
    -- Get weapon
    local weapon = getKatanaPistol()
    if not weapon then
        weapon = equipSecondWeapon()
        if not weapon then return false end
    end
    
    -- Get weapon handle
    local handle = weapon:FindFirstChild("Handle")
    if not handle then return false end
    
    -- Get target position
    local targetChar = targetPlayer.Character
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart") or targetChar:FindFirstChild("Torso")
    if not targetRoot then return false end
    
    -- Get our position (from handle)
    local startPos = handle.Position
    
    -- Calculate direction for beam
    local endPos = targetRoot.Position
    
    -- Execute the 3-step shooting sequence
    local success = true
    
    -- Step 1: Fire the "fire" remote
    local fireRemote = weapon:FindFirstChild("fire")
    if fireRemote and fireRemote:IsA("RemoteEvent") then
        pcall(function()
            fireRemote:FireServer()
        end)
    else
        success = false
        print("No fire remote found")
    end
    
    -- Step 2: Fire the "showBeam" remote
    local beamRemote = weapon:FindFirstChild("showBeam")
    if beamRemote and beamRemote:IsA("RemoteEvent") then
        pcall(function()
            local args = {
                startPos,
                endPos,
                handle
            }
            beamRemote:FireServer(unpack(args))
        end)
    else
        success = false
        print("No showBeam remote found")
    end
    
    -- Step 3: Fire the "kill" remote
    local killRemote = weapon:FindFirstChild("kill")
    if killRemote and killRemote:IsA("RemoteEvent") then
        pcall(function()
            local args = {
                targetPlayer,
                (endPos - startPos).Unit -- Direction vector
            }
            killRemote:FireServer(unpack(args))
        end)
    else
        success = false
        print("No kill remote found")
    end
    
    -- Also try the ReplicatedStorage kill remote
    if success then
        pcall(function()
            local replicatedKill = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
            if replicatedKill then
                local killedRemote = replicatedKill:FindFirstChild("Killed")
                if killedRemote then
                    killedRemote:FireServer(targetPlayer)
                end
            end
        end)
    end
    
    return success
end

-- Main toggle function
Button.MouseButton1Click:Connect(function()
    autoAiming = not autoAiming
    
    if autoAiming then
        Button.BackgroundColor3 = Color3.fromRGB(50, 255, 50)
        Button.Text = "AIMING..."
        
        -- Start aim loop
        connection = RunService.RenderStepped:Connect(function()
            if autoAiming then
                -- Check cooldown
                local currentTime = tick()
                if currentTime - lastShot >= shotCooldown then
                    -- Get nearest enemy
                    local nearestEnemy = getNearestEnemy()
                    if nearestEnemy then
                        -- Shoot enemy
                        local success = shootEnemy(nearestEnemy)
                        if success then
                            lastShot = currentTime
                            Button.Text = "SHOOTING!"
                            task.wait(0.1)
                            Button.Text = "AIMING..."
                        else
                            Button.Text = "NO WEAPON"
                            task.wait(0.5)
                            Button.Text = "AIMING..."
                        end
                    else
                        Button.Text = "NO TARGET"
                        task.wait(0.5)
                        Button.Text = "AIMING..."
                    end
                end
            end
        end)
        
        print("Perfect Auto-Aim activated!")
        print("Using KatanaPistol fire -> showBeam -> kill sequence")
        
    else
        Button.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        Button.Text = "PERFECT AIM"
        
        -- Disconnect the loop
        if connection then
            connection:Disconnect()
            connection = nil
        end
        
        print("Auto-aim deactivated")
    end
end)

