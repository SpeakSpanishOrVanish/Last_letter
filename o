-- One-Shot Aimbot for Duels: Murderers vs Sheriffs
-- Stable drag + position memory + visible hollow circle (no blur errors)

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

-- Settings
local cooldownTime = 2.5
local lastShotTime = 0
local canShoot = true

-- GUI
local ScreenGui = nil
local Button = nil

-- Position memory (saved across respawns)
local savedPosition = UDim2.new(0.5, -30, 0, 10)  -- 60px button

-- Dragging state
local isDragging = false
local dragOffset = Vector2.zero
local dragThreshold = 8

-- Cache
local camera = Workspace.CurrentCamera
local localBeam = ReplicatedStorage:FindFirstChild("BindableEvents"):FindFirstChild("LocalBeam")
local killedRemote = ReplicatedStorage:FindFirstChild("Remotes"):FindFirstChild("Killed")

-- Clamp to screen
local function clampToScreen(guiObject, position)
    local screenSize = camera.ViewportSize
    local buttonSize = guiObject.AbsoluteSize
    return UDim2.new(0, math.clamp(position.X.Offset, 0, screenSize.X - buttonSize.X), 0, math.clamp(position.Y.Offset, 0, screenSize.Y - buttonSize.Y))
end

-- Create GUI
local function createGUI()
    if ScreenGui then ScreenGui:Destroy() end
    
    local playerGui = player:WaitForChild("PlayerGui")
    
    ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "OneShotAimbotGUI"
    ScreenGui.Parent = playerGui
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.IgnoreGuiInset = true
    ScreenGui.ResetOnSpawn = false
    
    -- Hollow circle button (60x60)
    Button = Instance.new("TextButton")
    Button.Size = UDim2.new(0, 60, 0, 60)
    Button.Position = savedPosition
    Button.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Button.BackgroundTransparency = 0.5  -- Visible but see-through
    Button.Text = ""  -- No icon
    Button.Font = Enum.Font.GothamBold
    Button.TextSize = 0
    Button.Parent = ScreenGui
    Button.ZIndex = 10
    Button.Active = true
    Button.AutoButtonColor = false
    Button.BorderSizePixel = 0
    
    -- Rounded corners (fully circular)
    local corner = Instance.new("UICorner", Button)
    corner.CornerRadius = UDim.new(1, 0)
    
    -- White outline
    local stroke = Instance.new("UIStroke", Button)
    stroke.Thickness = 2.5
    stroke.Color = Color3.fromRGB(255, 255, 255)
    stroke.Transparency = 0.2
    
    -- === PROVEN STABLE DRAGGING (from working version) ===
    local function onDrag(input)
        if not isDragging then return end
        
        local currentPos = UserInputService:GetMouseLocation()
        local newX = currentPos.X - dragOffset.X
        local newY = currentPos.Y - dragOffset.Y
        
        local newPosition = UDim2.new(0, newX, 0, newY)
        local clamped = clampToScreen(Button, newPosition)
        Button.Position = clamped
        savedPosition = clamped  -- Save position for respawn
    end
    
    Button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mousePos = UserInputService:GetMouseLocation()
            local buttonPos = Button.AbsolutePosition
            dragOffset = mousePos - buttonPos
            isDragging = true
            
            -- Connect to InputChanged for movement
            local connection
            connection = UserInputService.InputChanged:Connect(function(changedInput)
                if changedInput == input then
                    onDrag(changedInput)
                end
            end)
            
            -- Cleanup on release
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    isDragging = false
                    connection:Disconnect()
                end
            end)
        end
    end)
    
    -- === SHOOTING (tap only) ===
    local dragStartPos = nil
    Button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragStartPos = UserInputService:GetMouseLocation()
        end
    end)
    
    local function tryShoot()
        if not canShoot then return end
        local endPos = UserInputService:GetMouseLocation()
        if dragStartPos and (endPos - dragStartPos).Magnitude <= dragThreshold then
            task.spawn(attemptShot)
        end
    end
    
    Button.MouseButton1Click:Connect(tryShoot)
    Button.TouchTap:Connect(tryShoot)
    
    -- Reset visuals
    canShoot = true
    lastShotTime = 0
    stroke.Color = Color3.fromRGB(255, 255, 255)
end

-- === Weapon & Combat Functions ===
local function getWeapon()
    local char = player.Character
    if not char then return nil end
    for _, tool in pairs(char:GetChildren()) do
        if tool:IsA("Tool") and tool:FindFirstChild("fire") then return tool end
    end
    local bp = player:FindFirstChild("Backpack")
    if bp then
        for _, tool in pairs(bp:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("fire") then
                tool.Parent = char
                return tool
            end
        end
    end
    return nil
end

local function hasClearLineOfSight(targetPlayer)
    local char = player.Character
    local tChar = targetPlayer.Character
    if not char or not tChar then return false end
    local myRoot = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    local tRoot = tChar:FindFirstChild("HumanoidRootPart") or tChar:FindFirstChild("Torso")
    if not myRoot or not tRoot then return false end
    local startPos = myRoot.Position
    local endPos = tRoot.Position
    local dir = (endPos - startPos).Unit
    local dist = (endPos - startPos).Magnitude
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {char, tChar}
    params.IgnoreWater = true
    return workspace:Raycast(startPos, dir * dist, params) == nil
end

local function getNearestVisibleEnemy()
    local char = player.Character
    if not char then return nil end
    local myRoot = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if not myRoot then return nil end
    local nearest, minDist = nil, math.huge
    for _, other in pairs(Players:GetPlayers()) do
        if other ~= player and other.Character then
            local oChar = other.Character
            local hum = oChar:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local oRoot = oChar:FindFirstChild("HumanoidRootPart") or oChar:FindFirstChild("Torso")
                if oRoot then
                    local dist = (myRoot.Position - oRoot.Position).Magnitude
                    if dist < minDist and hasClearLineOfSight(other) then
                        minDist = dist
                        nearest = other
                    end
                end
            end
        end
    end
    return nearest
end

local function shootEnemy(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return false end
    local char = player.Character
    if not char then return false end
    local weapon = getWeapon()
    if not weapon then return false end
    local handle = weapon:FindFirstChild("Handle")
    if not handle then return false end
    local tRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart") or targetPlayer.Character:FindFirstChild("Torso")
    if not tRoot then return false end
    
    local startPos = handle.Position
    local hitPos = tRoot.Position
    
    if localBeam then pcall(function() localBeam:Fire(handle, hitPos) end) end
    
    local fireRemote = weapon:FindFirstChild("fire")
    if fireRemote then pcall(function() fireRemote:FireServer() end) end
    
    local beamRemote = weapon:FindFirstChild("showBeam")
    if beamRemote then pcall(function() beamRemote:FireServer(hitPos, startPos, handle) end) end
    
    local killRemote = weapon:FindFirstChild("kill")
    if killRemote then
        local dir = (hitPos - startPos).Unit
        pcall(function() killRemote:FireServer(targetPlayer, dir) end)
    end
    
    if killedRemote then pcall(function() killedRemote:FireServer(targetPlayer) end) end
    
    return true
end

local function startCooldown()
    canShoot = false
    lastShotTime = tick()
    -- Outline turns gray
    local stroke = Button:FindFirstChildOfClass("UIStroke")
    if stroke then stroke.Color = Color3.fromRGB(150, 150, 150) end
    
    task.spawn(function()
        while tick() - lastShotTime < cooldownTime do task.wait(0.1) end
        canShoot = true
        if stroke then stroke.Color = Color3.fromRGB(255, 255, 255) end
    end)
end

function attemptShot()
    if not canShoot then return end
    if not getWeapon() then return end
    local target = getNearestVisibleEnemy()
    if target and shootEnemy(target) then
        startCooldown()
    end
end

-- Respawn handling
player.CharacterAdded:Connect(function()
    task.wait(0.1)
    createGUI()
    camera = Workspace.CurrentCamera
end)

if player.Character then
    createGUI()
else
    player.CharacterAdded:Wait()
    createGUI()
end

print("Aimbot Loaded – Stable drag, position saved, visible circle!")
